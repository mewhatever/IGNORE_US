# PostgreSQL (local Docker)
POSTGRES_USER=queuestorm
POSTGRES_PASSWORD=queuestorm_secret
POSTGRES_DB=queuestorm
POSTGRES_PORT=5434

# Backend
PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://queuestorm:queuestorm_secret@localhost:5434/queuestorm

# Production (Neon / Supabase / Vercel Postgres) — must include SSL
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# JWT — use 32+ random chars in production (openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h

# CORS — comma-separated origins (set to your Vercel URL in production)
# Example: https://queuestorm.vercel.app
CORS_ORIGIN=http://localhost:5173

# Demo agent (seeded on first boot — change password before public deploy)
DEMO_AGENT_EMAIL=agent@queuestorm.demo
DEMO_AGENT_PASSWORD=Agent@2026

# Classifier: rules | llm | hybrid (default hybrid = LLM first, rules fallback)
CLASSIFIER_MODE=hybrid

# LLM provider: groq | deepseek | gemini | ollama
LLM_PROVIDER=groq

# Groq — free tier: https://console.groq.com/keys
GROQ_API_KEY=

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama — local only (not usable on Vercel)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

LLM_MODEL=
LLM_TIMEOUT_MS=15000

# Frontend (only needed if API is on a different domain)
# Leave empty when frontend + API share the same Vercel domain
VITE_API_URL=
