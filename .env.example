# PostgreSQL (Docker)
POSTGRES_USER=queuestorm
POSTGRES_PASSWORD=queuestorm_secret
POSTGRES_DB=queuestorm
POSTGRES_PORT=5434

# Backend
PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://queuestorm:queuestorm_secret@localhost:5434/queuestorm

# JWT — change in production
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h

# CORS — comma-separated origins
CORS_ORIGIN=http://localhost:5173

# Demo agent (seeded on first boot)
DEMO_AGENT_EMAIL=agent@queuestorm.demo
DEMO_AGENT_PASSWORD=Agent@2026

# Classifier: rules | llm | hybrid (default hybrid = LLM first, rules fallback)
CLASSIFIER_MODE=hybrid

# LLM provider: groq | deepseek | gemini | ollama
LLM_PROVIDER=groq

# Groq — free tier: https://console.groq.com/keys
GROQ_API_KEY=

# DeepSeek — ~5M free tokens on signup: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Gemini — free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama — free local LLM: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional model override (deepseek-chat | deepseek-reasoner | deepseek-v4-flash | llama-3.1-8b-instant)
LLM_MODEL=
LLM_TIMEOUT_MS=15000
